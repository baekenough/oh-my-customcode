#!/bin/sh

# Pre-commit hook for oh-my-customcode
# Runs typecheck, lint, and tests before allowing commit

# Worktree detection: .git is a file (not directory) in worktrees
if [ -f .git ]; then
    echo "Running pre-commit checks (worktree mode)..."
    bun run typecheck 2>/dev/null || exit 1
    echo "Worktree pre-commit passed (typecheck only — full suite runs in CI)."
    exit 0
fi

echo "Running pre-commit checks..."

# Run TypeScript type checking
echo "Checking types..."
bun run typecheck
if [ $? -ne 0 ]; then
    echo "Type check failed. Please fix the errors before committing."
    exit 1
fi

# Auto-fix lint issues on staged files
echo "Running lint auto-fix..."

# Collect staged files by type
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)
STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.go$' || true)

# TypeScript/JavaScript: Biome
if [ -n "$STAGED_TS" ]; then
    echo "  [Biome] Formatting $(echo "$STAGED_TS" | wc -l | tr -d ' ') files..."
    echo "$STAGED_TS" | xargs npx biome check --write --no-errors-on-unmatched 2>/dev/null
    echo "$STAGED_TS" | xargs git add -f
fi

# Python: Ruff
if [ -n "$STAGED_PY" ]; then
    if command -v ruff >/dev/null 2>&1; then
        echo "  [Ruff] Formatting $(echo "$STAGED_PY" | wc -l | tr -d ' ') files..."
        echo "$STAGED_PY" | xargs ruff check --fix --quiet 2>/dev/null
        echo "$STAGED_PY" | xargs ruff format --quiet 2>/dev/null
        echo "$STAGED_PY" | xargs git add -f
    fi
fi

# Go: gofmt
if [ -n "$STAGED_GO" ]; then
    if command -v gofmt >/dev/null 2>&1; then
        echo "  [gofmt] Formatting $(echo "$STAGED_GO" | wc -l | tr -d ' ') files..."
        echo "$STAGED_GO" | xargs gofmt -w 2>/dev/null
        echo "$STAGED_GO" | xargs git add -f
    fi
fi

# Final lint check (should pass after auto-fix)
bun run lint
if [ $? -ne 0 ]; then
    echo "Lint errors remain after auto-fix. Please fix manually."
    exit 1
fi

# Run tests with coverage
echo "Running tests with coverage..."
COVERAGE_OUTPUT=$(bun test --coverage 2>&1)
TEST_EXIT_CODE=$?
echo "$COVERAGE_OUTPUT"

# Check if tests passed first
if [ $TEST_EXIT_CODE -ne 0 ]; then
    if echo "$COVERAGE_OUTPUT" | grep -q "pass" && echo "$COVERAGE_OUTPUT" | grep -qE '^ *0 fail'; then
        :
    else
        echo "Tests failed. Please fix the failing tests before committing."
        exit 1
    fi
fi

# Extract coverage percentages from "All files" line
COVERAGE_LINE=$(echo "$COVERAGE_OUTPUT" | grep -E "All files.*\|")

if [ -n "$COVERAGE_LINE" ]; then
    FUNC_COV=$(echo "$COVERAGE_LINE" | awk -F'|' '{print $2}' | tr -d ' ')
    LINE_COV=$(echo "$COVERAGE_LINE" | awk -F'|' '{print $3}' | tr -d ' ')

    echo "Function coverage: $FUNC_COV%"
    echo "Line coverage: $LINE_COV%"

    # Pre-commit threshold (dynamic: relaxed for commits with new source files)
    # Detect newly added source files for dynamic threshold
    NEW_SOURCE_FILES=$(git diff --cached --name-only --diff-filter=A | grep -E '^src/.*\.(ts|tsx)$' || true)
    THRESHOLD=98
    if [ -n "$NEW_SOURCE_FILES" ]; then
        NEW_COUNT=$(echo "$NEW_SOURCE_FILES" | wc -l | tr -d ' ')
        THRESHOLD=95
        echo "[NEW FILES] $NEW_COUNT new source file(s) detected — threshold relaxed to ${THRESHOLD}%"
        echo "$NEW_SOURCE_FILES" | while read -r f; do echo "  [NEW] $f"; done
        echo "Note: Next commit without new files requires ${THRESHOLD}% → 98% coverage."
    fi

    FUNC_OK=$(echo "$FUNC_COV $THRESHOLD" | awk '{print ($1 >= $2) ? "1" : "0"}')
    LINE_OK=$(echo "$LINE_COV $THRESHOLD" | awk '{print ($1 >= $2) ? "1" : "0"}')

    if [ "$FUNC_OK" != "1" ] || [ "$LINE_OK" != "1" ]; then
        echo "Coverage below threshold. Function: $FUNC_COV%, Line: $LINE_COV% (required: >= $THRESHOLD%)"
        echo ""
        echo "=== Uncovered files and lines ==="
        echo "$COVERAGE_OUTPUT" | grep -E "Uncovered lines:" | while IFS='|' read -r file func line rest; do
            file=$(echo "$file" | xargs)
            uncovered=$(echo "$rest" | sed 's/.*Uncovered lines: *//')
            if [ -n "$uncovered" ]; then
                echo "  $file → lines: $uncovered"
            fi
        done
        echo ""
        echo "Fix: Add tests covering the lines above, then retry commit."
        exit 1
    fi

    echo "Coverage check passed: Function $FUNC_COV%, Line $LINE_COV% (threshold: $THRESHOLD%)"
fi

# Validate agent/skill/guide counts match CLAUDE.md
echo "Checking documentation counts..."
ACTUAL_AGENTS=$(ls .claude/agents/*.md 2>/dev/null | wc -l | tr -d ' ')
ACTUAL_SKILLS=$(find .claude/skills -name 'SKILL.md' 2>/dev/null | wc -l | tr -d ' ')

DOC_AGENTS=$(grep -oE 'agents/[[:space:]]+#[[:space:]]+서브에이전트 정의 \([0-9]+' CLAUDE.md 2>/dev/null | grep -oE '[0-9]+$' || echo "0")
DOC_SKILLS=$(grep -oE 'skills/[[:space:]]+#[[:space:]]+스킬 \([0-9]+' CLAUDE.md 2>/dev/null | grep -oE '[0-9]+$' || echo "0")

# Fallback: try alternate patterns
if [ "$DOC_AGENTS" = "0" ]; then
    DOC_AGENTS=$(grep -oP '에이전트 정의 \(\K[0-9]+' CLAUDE.md 2>/dev/null || grep -oP '\((\K[0-9]+) 파일\)' CLAUDE.md 2>/dev/null || echo "0")
fi
if [ "$DOC_SKILLS" = "0" ]; then
    DOC_SKILLS=$(grep -oP '스킬 \(\K[0-9]+' CLAUDE.md 2>/dev/null || grep -oP 'skills.*\((\K[0-9]+)' CLAUDE.md 2>/dev/null || echo "0")
fi

COUNT_ERRORS=0
if [ "$ACTUAL_AGENTS" != "$DOC_AGENTS" ] && [ "$DOC_AGENTS" != "0" ]; then
    echo "⚠ CLAUDE.md agent count ($DOC_AGENTS) != actual ($ACTUAL_AGENTS)"
    COUNT_ERRORS=$((COUNT_ERRORS + 1))
fi
if [ "$ACTUAL_SKILLS" != "$DOC_SKILLS" ] && [ "$DOC_SKILLS" != "0" ]; then
    echo "⚠ CLAUDE.md skill count ($DOC_SKILLS) != actual ($ACTUAL_SKILLS)"
    COUNT_ERRORS=$((COUNT_ERRORS + 1))
fi
if [ "$COUNT_ERRORS" -gt 0 ]; then
    echo "Documentation count mismatch detected. Update CLAUDE.md before committing."
    exit 1
fi
echo "Documentation counts verified."

echo "All pre-commit checks passed!"
