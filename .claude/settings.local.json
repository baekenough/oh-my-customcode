{
  "permissions": {
    "allow": [
      "Bash(bun run:*)",
      "Bash(bun test:*)",
      "Bash(bun add:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(python3:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(chmod:*)",
      "Bash(cp .claude/skills/research/SKILL.md templates/.claude/skills/research/SKILL.md)",
      "Bash(cp .claude/skills/agora/SKILL.md templates/.claude/skills/agora/SKILL.md)",
      "Bash(cp .claude/skills/evaluator-optimizer/SKILL.md templates/.claude/skills/evaluator-optimizer/SKILL.md)",
      "Bash(cp .claude/skills/worker-reviewer-pipeline/SKILL.md templates/.claude/skills/worker-reviewer-pipeline/SKILL.md)",
      "Bash(cp .claude/skills/multi-model-verification/SKILL.md templates/.claude/skills/multi-model-verification/SKILL.md)",
      "Bash(rm -f templates/.claude/agents/lang-java21-expert.md)",
      "Bash(rm -rf templates/.claude/skills/java21-best-practices)",
      "Bash(rm -rf templates/guides/java21)",
      "Bash(rm templates/.claude/agents/lang-java21-expert.md)",
      "Bash(rm -r templates/.claude/skills/java21-best-practices)",
      "Bash(rm -r templates/guides/java21)",
      "Bash(cp .claude/agents/lang-java-expert.md templates/.claude/agents/lang-java-expert.md)",
      "Bash(mkdir -p templates/.claude/skills/java-best-practices)",
      "Bash(cp .claude/skills/java-best-practices/SKILL.md templates/.claude/skills/java-best-practices/SKILL.md)",
      "Bash(mkdir -p templates/guides/java)",
      "Bash(cp guides/java/modern-java.md templates/guides/java/modern-java.md)",
      "Bash(cp .claude/agents/be-springboot-expert.md templates/.claude/agents/be-springboot-expert.md)",
      "Bash(cp .claude/agents/de-airflow-expert.md templates/.claude/agents/de-airflow-expert.md)",
      "Bash(cp .claude/agents/de-kafka-expert.md templates/.claude/agents/de-kafka-expert.md)",
      "Bash(cp .claude/agents/de-spark-expert.md templates/.claude/agents/de-spark-expert.md)",
      "Bash(cp .claude/agents/fe-flutter-agent.md templates/.claude/agents/fe-flutter-agent.md)",
      "Bash([ -f \".claude/skills/$skill/SKILL.md\" ])",
      "Bash([ -d \"templates/.claude/skills/$skill\" ])",
      "Bash(cp .claude/skills/__TRACKED_VAR__/SKILL.md templates/.claude/skills/__TRACKED_VAR__/SKILL.md)",
      "Bash(cp .claude/ontology/agents.yaml templates/.claude/ontology/agents.yaml)",
      "Bash(cp .claude/ontology/skills.yaml templates/.claude/ontology/skills.yaml)",
      "Bash(cp .claude/agents/lang-java-expert.md templates/.claude/agents/)",
      "Bash(cp .claude/skills/java-best-practices/SKILL.md templates/.claude/skills/java-best-practices/)",
      "Bash(cp -r guides/java/* templates/guides/java/)",
      "Bash(cp CLAUDE.md templates/CLAUDE.md)",
      "Bash(cp .claude/skills/update-docs/SKILL.md templates/.claude/skills/update-docs/SKILL.md)",
      "Bash(cp .claude/skills/intent-detection/patterns/agent-triggers.yaml templates/.claude/skills/intent-detection/patterns/agent-triggers.yaml)",
      "Bash(rm templates/.claude/skills/java21-best-practices/SKILL.md)",
      "Bash(rmdir templates/.claude/skills/java21-best-practices)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "ontology-rag"
  ],
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh",
    "padding": 0,
    "refreshInterval": 10
  }
}
