|   |   +-- fe-vercel-agent/
|   |   +-- mgr-creator/
|   |   +-- sys-memory-keeper/
|   |   +-- ... (34 total)
|   +-- skills/                  # Skill definitions
|   |   +-- routing/
|   |   +-- development/
|   |   +-- backend/
|   |   +-- infrastructure/
|   |   +-- system/
+-- guides/                      # Reference docs
+-- pipelines/                   # Pipeline definitions
```

