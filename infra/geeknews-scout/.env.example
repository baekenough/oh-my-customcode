# geeknews-scout deployment configuration
# Copy to .env and edit before running deploy.sh

# SSH target for k3s server
K3S_SERVER=your-server-alias

# Kubernetes namespace
K8S_NAMESPACE=omcustom

# Docker image
IMAGE_NAME=geeknews-scout
IMAGE_TAG=latest

# GitHub token (repo + issues:write scopes)
GH_TOKEN=

# Target repository for issue creation
TARGET_REPO=baekenough/oh-my-customcode

# GeekNews RSS feed URL
FEED_URL=http://feeds.feedburner.com/geeknews-feed

# Keywords filter (pipe-separated regex, case-insensitive)
KEYWORDS=Claude|Anthropic|MCP|Model Context Protocol|AI agent|에이전트|코드 에이전트|agent orchestr|Claude Code|coding agent|agentic|multi-agent|LLM tool|developer tool|CLI agent|코딩 에이전트

# CronJob schedule (default: every 6 hours UTC)
CRON_SCHEDULE=0 */6 * * *
