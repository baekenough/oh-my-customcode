# hada-scout deployment configuration
# Copy to .env and edit before running deploy.sh

# SSH target for k3s server
K3S_SERVER=your-server-alias

# Kubernetes namespace (shared with geeknews-scout)
K8S_NAMESPACE=omcustom

# Docker image
IMAGE_NAME=hada-scout
IMAGE_TAG=latest

# GitHub token (repo + issues:write scopes)
GH_TOKEN=

# Target repository for issue creation
TARGET_REPO=baekenough/oh-my-customcode

# hada.io RSS feed URL (same feedburner as geeknews)
FEED_URL=http://feeds.feedburner.com/geeknews-feed

# Keywords filter — harness/benchmark/eval focused
# (broad AI agent keywords handled by geeknews-scout)
KEYWORDS=harness|benchmark|eval|evaluation framework|agent framework|코드 리뷰 자동화|하네스|벤치마크|평가

# Max issues to create per check-feed run (cost control)
MAX_SCOUT_ENTRIES=5

# CronJob schedule — check-feed.sh (default: daily at 09:00 UTC)
CRON_SCHEDULE_FEED=0 9 * * *

# CronJob schedule — scout-runner.sh (default: daily at 10:00 UTC, 1h after feed check)
CRON_SCHEDULE_SCOUT=0 10 * * *

# Max /scout executions per scout-runner run
MAX_SCOUT_PER_RUN=5

# Claude project directory on host (for scout-runner.sh host execution)
CLAUDE_PROJECT_DIR=/workspace/oh-my-customcode
