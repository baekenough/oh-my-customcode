# cc-release-collector deployment configuration
# Copy to .env and edit before running deploy.sh

# SSH target for the k3s server (e.g., user@hostname, or SSH config alias)
K3S_SERVER=your-server-alias

# Kubernetes namespace to deploy into
K8S_NAMESPACE=omcustom

# Docker image name
IMAGE_NAME=cc-release-collector
IMAGE_TAG=latest

# GitHub token with repo + issues:write scopes
# Generate at: https://github.com/settings/tokens/new
GH_TOKEN=

# Target repository for issue creation
TARGET_REPO=baekenough/oh-my-customcode

# Source repository to watch for releases
SOURCE_REPO=anthropics/claude-code

# Minimum version to track (inclusive)
MIN_VERSION=2.1.86

# CronJob schedule (default: daily 9AM UTC = 6PM KST)
CRON_SCHEDULE="0 9 * * *"
